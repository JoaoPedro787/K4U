{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es6",
    "module": "commonjs",
    "paths": {
      "@config/*": ["./src/config/*"],
      "@controller/*": ["./src/controller/*"],
      "@database/*": ["./src/database/*"],
      "@exceptions/*": ["./src/exceptions/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@models/*": ["./src/models/*"],
      "@routes/*": ["./src/routes/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@services/*": ["./src/services/*"],
      "@utils/*": ["./src/utils/*"],
      "@mappers/*": ["./src/mappers/*"],
      "@paginations/*": ["./src/paginations/*"]
    }
  },
  "include": ["src/**/*"]
}
