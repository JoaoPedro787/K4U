{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es6",
    "module": "commonjs",
    "paths": {
      "@/*": ["src/*"],
      "@configs/*": ["src/configs/*"],
      "@controllers/*": ["./src/controller/*"],
      "@exceptions/*": ["./src/exceptions/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@models/*": ["./src/models/*"],
      "@routes/*": ["./src/routes/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@services/*": ["./src/services/*"],
      "@utils/*": ["./src/utils/*"],
      "@mappers/*": ["./src/mappers/*"],
      "@paginations/*": ["./src/paginations/*"],
      "@repositories/*": ["./src/repositories/*"]
    }
  },
  "include": ["src/**/*"]
}
